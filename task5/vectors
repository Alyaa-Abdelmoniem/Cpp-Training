#include <iostream>
#include <vector>
using namespace std;

int main()
{
    vector<int> v = {1, 2, 3, 4, 5};

    cout << "Original Vector: ";
    for (int x : v)
        cout << x << " ";
    cout << endl << endl;

    cout << "Size = " << v.size() << endl;
    cout << "Capacity = " << v.capacity() << endl;
    cout << "Max Size = " << v.max_size() << endl << endl;

    cout << "First Element = " << v.front() << endl;
    cout << "Last Element = " << v.back() << endl;
    cout << "Element at index 2 = " << v.at(2) << endl;
    cout << "Element at index 3 = " << v[3] << endl << endl;

    v.push_back(6);
    cout << "After push_back(6): ";
    for (int x : v)
        cout << x << " ";
    cout << endl;

    v.pop_back();
    cout << "After pop_back(): ";
    for (int x : v)
        cout << x << " ";
    cout << endl;

    v.insert(v.begin() + 2, 10);
    cout << "After insert 10: ";
    for (int x : v)
        cout << x << " ";
    cout << endl;

    v.erase(v.begin() + 2);
    cout << "After erase: ";
    for (int x : v)
        cout << x << " ";
    cout << endl;

    v.resize(7);
    cout << "After resize(7): ";
    for (int x : v)
        cout << x << " ";
    cout << endl;

    v.assign(3, 100);
    cout << "After assign(3,100): ";
    for (int x : v)
        cout << x << " ";
    cout << endl;

    v.clear();
    cout << "After clear(), Size = " << v.size() << endl << endl;

    v = {5, 4, 3, 2, 1};

    cout << "Using begin() and end(): ";
    for (auto it = v.begin(); it != v.end(); it++)
        cout << *it << " ";
    cout << endl;

    cout << "Using rbegin() and rend(): ";
    for (auto it = v.rbegin(); it != v.rend(); it++)
        cout << *it << " ";
    cout << endl;

    vector<int> v2 = {100, 200};
    v.swap(v2);

    cout << "After swap, v = ";
    for (int x : v)
        cout << x << " ";
    cout << endl;

    v.reserve(10);
    cout << "Capacity after reserve = " << v.capacity() << endl;

    v.shrink_to_fit();
    cout << "Capacity after shrink_to_fit = " << v.capacity() << endl;

    cout << "First element using data() = " << *v.data() << endl;

    return 0;
}
