#include <iostream>
#include <string>
using namespace std;

class Vehicle
{
protected:
    string name;
    int maxSpeed;
    int tires;

public:
    Vehicle(string n, int s, int t)
    {
        name = n;
        maxSpeed = s;
        tires = t;
    }

    virtual string type() const
    {
        return "Vehicle";
    }

    virtual void show() const
    {
        cout << "Type: " << type() << endl;
        cout << "Brand: " << name << endl;
        cout << "Speed: " << maxSpeed << " km/h" << endl;
        cout << "Wheels: " << tires << endl;
    }

    virtual ~Vehicle() {}
};

class Car : public Vehicle
{
public:
    Car(string n, int s) : Vehicle(n, s, 4) {}

    string type() const override
    {
        return "Car";
    }
};

class Truck : public Vehicle
{
protected:
    double load;

public:
    Truck(string n, int s, double l) : Vehicle(n, s, 6)
    {
        load = l;
    }

    string type() const override
    {
        return "Truck";
    }

    void show() const override
    {
        Vehicle::show();
        cout << "Load: " << load << " tons" << endl;
    }
};

class Plane : public Vehicle
{
protected:
    int height;

public:
    Plane(string n, int s, int h) : Vehicle(n, s, 3)
    {
        height = h;
    }

    string type() const override
    {
        return "Plane";
    }

    void show() const override
    {
        Vehicle::show();
        cout << "Max Height: " << height << " m" << endl;
    }
};

class Bike : public Vehicle
{
public:
    Bike(string n, int s) : Vehicle(n, s, 2) {}

    string type() const override
    {
        return "Bike";
    }
};

class Bicycle : public Vehicle
{
public:
    Bicycle(string n, int s) : Vehicle(n, s, 2) {}

    string type() const override
    {
        return "Bicycle";
    }

    void show() const override
    {
        Vehicle::show();
        cout << "Engine: No" << endl;
    }
};

class BMW : public Car
{
    string model;

public:
    BMW(int s, string m) : Car("BMW", s)
    {
        model = m;
    }

    string type() const override
    {
        return "BMW " + model;
    }
};

class Hyundai : public Car
{
    string model;

public:
    Hyundai(int s, string m) : Car("Hyundai", s)
    {
        model = m;
    }

    string type() const override
    {
        return "Hyundai " + model;
    }
};

class Airbus : public Plane
{
    string model;

public:
    Airbus(int s, int h, string m) : Plane("Airbus", s, h)
    {
        model = m;
    }

    string type() const override
    {
        return "Airbus " + model;
    }
};

class Volvo : public Truck
{
    string model;

public:
    Volvo(int s, double l, string m) : Truck("Volvo", s, l)
    {
        model = m;
    }

    string type() const override
    {
        return "Volvo " + model;
    }
};

class Yamaha : public Bike
{
    string model;

public:
    Yamaha(int s, string m) : Bike("Yamaha", s)
    {
        model = m;
    }

    string type() const override
    {
        return "Yamaha " + model;
    }
};

int main()
{
    Vehicle* vehicles[] =
    {
        new BMW(260, "X6"),
        new Hyundai(190, "Elantra"),
        new Volvo(110, 15.0, "FH16"),
        new Airbus(850, 12000, "A320"),
        new Yamaha(210, "R6"),
        new Bicycle("Giant", 35)
    };

    for (int i = 0; i < 6; i++)
    {
        vehicles[i]->show();
        cout << "------------------------" << endl;
    }

    for (int i = 0; i < 6; i++)
    {
        delete vehicles[i];
    }

    return 0;
}
